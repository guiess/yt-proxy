{
	# Disable HTTP/3 (QUIC) — commonly blocked by Russian ISPs,
	# causing video playback to hang while the browser waits for
	# QUIC before falling back to HTTP/2.
	servers {
		protocols h1 h2
	}
}

{$DOMAIN} {
	tls {$ACME_EMAIL}

	log {
		output stdout
		format console
		level INFO
	}

	# Companion endpoints (video stream proxying)
	handle /companion/* {
		reverse_proxy {$COMPANION_HOST:companion}:8282
	}

	# Everything else goes to Invidious
	handle {
		reverse_proxy {$INVIDIOUS_HOST:invidious}:3000
	}
}
